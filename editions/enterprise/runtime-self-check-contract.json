{
  "schema_version": 1,
  "contract_id": "beijixing-enterprise-runtime-self-check",
  "status": "offline_policy_defined",
  "tiers": {
    "startup": ["contract_references", "policy_versions", "route_index", "required_files"],
    "background": ["workflow_references", "memory_expiry_conflicts", "evidence_index_metadata", "source_freshness"],
    "L4_preflight": ["fresh_authoritative_sources", "calculation_basis", "grant_scope", "rollback_path", "revocation_path"]
  },
  "background_priority": 0,
  "background_preemptible": true,
  "non_destructive": true,
  "restore_original_state_after_probe": true,
