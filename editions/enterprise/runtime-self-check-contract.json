  "restart_table": {
    "recoverable": ["restore", "retry_bounded", "degrade_capability"],
    "insufficient_evidence": ["freeze", "revoke", "fresh_start"],
    "never": ["hide_alarm", "continue_with_false_certainty", "expand_permission"]
  },
  "control_execution_separation": "self_check_reports_to_broker_and_cannot_approve_business_output",
  "production_authority": "none"
