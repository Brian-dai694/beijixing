{
  "schema_version": 1,
  "policy_id": "qianlima-personal-progressive-governance",
  "principle": "Default interaction is frictionless; governance becomes visible only when risk, ambiguity, evidence, or reversibility requires it.",
  "service_levels": {
    "L0": {"mode": "quick", "governance_visibility": "silent", "shadow_check": "suppressed", "confirmation_required": false},
    "L1": {"mode": "quick", "governance_visibility": "silent", "shadow_check": "suppressed", "confirmation_required": false},
    "L2": {"mode": "quick", "governance_visibility": "quiet", "shadow_check": "suppressed", "confirmation_required": false},
    "L3": {"mode": "evidence", "governance_visibility": "evidence", "shadow_check": "background_if_budget_allows", "confirmation_required": false},
    "L4": {"mode": "controlled", "governance_visibility": "explicit", "shadow_check": "candidate_only", "confirmation_required": true}
  },
  "memory_classes": {
    "task_state": {"default_state": "current", "expires": "task_end", "user_visible": true, "editable": false, "deletable": true},
    "explicit_preference": {"default_state": "current", "source": "user_statement_or_correction", "user_visible": true, "editable": true, "deletable": true},
    "observed_habit": {"default_state": "shadow_only", "source": "repeated_behavior", "user_visible": true, "editable": false, "deletable": true},
    "validated_work_mode": {"default_state": "current", "requires": ["three_observations", "independent_shadow_check", "user_confirmation"], "user_visible": true, "editable": true, "deletable": true},
    "sensitive_fact": {"default_state": "reference_only", "store_value": false, "user_visible": false, "editable": false, "deletable": true}
  },
  "learnable_preference_keys": [
    "communication_language",
    "response_style",
    "speed_preference",
    "quality_preference",
    "collaboration_style",
    "architecture_preference",
    "shadow_second_opinion",
    "tool_preference",
    "workflow_order",
    "workflow_default_parameters"
  ],
  "learning": {
    "lifecycle": ["explicit_or_repeated_signal", "shadow_candidate", "consistency_check", "user_confirmation", "suggestion_only", "user_edit_or_revoke"],
    "accepted_signal": "explicit_user_correction",
    "observed_behavior_effect": "shadow_only",
    "minimum_observations_for_promotion": 3,
    "promotion_requires_user_confirmation": true,
    "candidate_storage": ".qianlima/evolution/candidates",
    "automatic_global_rule_change": false,
    "permission_change_allowed": false,
    "data_scope_change_allowed": false,
    "tool_authority_change_allowed": false,
    "default_parameter_authority": "suggestion_only"
  },
  "sparse_selection": {
    "default_top_k": 5,
    "minimum_top_k": 3,
    "maximum_top_k": 8,
    "filter_order": ["task_class", "task_domain", "user_confirmed", "state_current", "not_expired", "confidence", "recent_use", "observation_count"],
    "inject_only_selected": true,
    "empty_selection_is_valid": true,
    "high_risk_authority": "none",
    "selector": ".qianlima/scripts/select-personal-preferences.ps1",
    "selection_is_sparse": true,
    "selection_must_be_task_relevant": true
  },
  "task_classes": {
    "chat": {"allowed_preference_effects": ["expression", "response_length", "language"]},
    "learning": {"allowed_preference_effects": ["expression", "response_length", "explanation_depth", "context_selection"]},
    "read_only_business": {"allowed_preference_effects": ["expression", "result_order", "context_selection", "shadow_check_preference", "tool_preference", "workflow_order", "workflow_default_parameters"]},
    "high_risk": {"allowed_preference_effects": ["expression", "receipt_format"], "permission_effect": "none"}
  },
  "preference_limits": {
    "cannot_change": ["network", "external_agent", "mcp", "file_read_scope", "file_export", "delete", "overwrite", "price", "bid", "budget", "purchase", "external_send", "confirmation_requirement"],
    "sensitive_values": "reference_only",
    "default_mode": "quick"
  },
  "success_criteria": {
    "north_star": "fewer_unnecessary_interruptions_without_boundary_crossing",
    "measures": [
      "repeated_explanation_reduced",
      "low_risk_confirmation_interruptions_reduced",
      "permission_expansion_from_learning_zero",
      "automatic_sensitive_profile_promotion_zero",
      "every_active_preference_user_visible_editable_deletable"
    ],
    "learning_must_not_optimize": ["autonomy", "permission_breadth", "external_action_rate", "silent_high_risk_completion"]
  },
  "personal_receipt": {
    "required_fields": ["action", "basis", "affected_scope", "confirmation_state", "rollback_ref"],
    "storage": ".qianlima/run-traces",
    "show_for": ["L4", "external_write", "delete", "overwrite", "user_requested_receipt"]
  }
}
